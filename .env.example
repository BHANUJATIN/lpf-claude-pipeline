# ─────────────────────────────────────────────────────────────────────────────
# LPF-Claude — environment variables
# Copy to .env (local) OR set in Heroku/Render/Railway dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (Stackhero or any managed Postgres) ────────────────────────────
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=true

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000               # Heroku/Render override this automatically
LOG_LEVEL=info
APP_PUBLIC_URL=         # https://<your-domain>  — used for Google OAuth redirect URI

# ── Required AI / discovery providers ───────────────────────────────────────
OPENAI_API_KEY=
APIFY_API_KEY=
FINDYMAIL_API_KEY=

# ── CRM ─────────────────────────────────────────────────────────────────────
RECRUITERFLOW_API_KEY=
RECRUITERFLOW_USER_ID=
RECRUITERFLOW_RATE_LIMIT_PER_MIN=30

# ── SAP-jobs Google Sheet writer (Apps Script web app) ──────────────────────
SAP_SHEET_APPS_SCRIPT_URL=

# ── Optional ────────────────────────────────────────────────────────────────
# Apollo (people search + harvest). Out of credits → search disabled, harvest still works.
APOLLO_API_KEY=

# HeyReach campaigns are saved in the Connections tab (lpf_connections),
# but env vars work too as a fallback:
HEYREACH_API_KEY=
HEYREACH_CAMPAIGN_FREE_INMAIL=
HEYREACH_CAMPAIGN_CONREQ_INMAIL=
HEYREACH_CAMPAIGN_CONNECT_ONLY=

# Instantly campaign — same pattern (DB connection takes precedence)
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=

# ── Pipeline tuning ─────────────────────────────────────────────────────────
PIPELINE_BATCH_SIZE=10
MIN_QUALITY_SCORE=5
STAGE_TIMEOUT_MS=240000
COMPANY_COOLDOWN_DAYS=30
PEOPLE_RETENTION_DAYS=30
WB2_PROMPT_TIMEOUT_MS=45000
HEYREACH_GEN_TIMEOUT_MS=60000
HEYREACH_GEN_PARALLEL=5
OPENAI_TIMEOUT_MS=60000
LINKEDIN_LIVE_CHECK=true
BOOT_RESUME=true
RETENTION_AUTORUN=true
